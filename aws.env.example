# ─── AWS S3 ───────────────────────────────────────────────────────────────────
# Región del bucket (e.g. eu-west-1, us-east-1)
AWS_REGION=eu-west-1

# Credenciales IAM — usa un usuario con permisos mínimos (ver política abajo)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Nombre del bucket
AWS_S3_BUCKET=samsara-photos-prod

# (Opcional) Si usas CloudFront, pon aquí la URL de la distribución.
# Si no, se construye automáticamente como https://<bucket>.s3.<region>.amazonaws.com
# AWS_S3_PUBLIC_URL=https://d1234abcd.cloudfront.net


# ─── Política IAM mínima para el usuario ──────────────────────────────────────
# Pega esto en la consola de IAM → Policies → Create policy → JSON
#
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "s3:PutObject",
#         "s3:DeleteObject"
#       ],
#       "Resource": "arn:aws:s3:::samsara-photos-prod/*"
#     }
#   ]
# }
#
# Sólo PutObject y DeleteObject — el backend nunca necesita leer ni listar.


# ─── Configuración CORS del bucket ────────────────────────────────────────────
# Entra en S3 → tu bucket → Permissions → CORS y pega esto:
#
# [
#   {
#     "AllowedHeaders": ["*"],
#     "AllowedMethods": ["PUT"],
#     "AllowedOrigins": ["*"],
#     "ExposeHeaders": ["ETag"],
#     "MaxAgeSeconds": 3000
#   }
# ]
#
# En producción, restringe AllowedOrigins a tu dominio real.
